#. Plugin Name of the plugin
#: ainbae-receipt-upload-for-woocommerce.php
msgid "Ainbae Receipt Upload for WooCommerce"
msgstr "Ainbae Téléchargement de reçus pour WooCommerce"

#. Description of the plugin
#: ainbae-receipt-upload-for-woocommerce.php
msgid "Allows customers to upload bank transfer receipts on the order detail page."
msgstr "Permet aux clients de télécharger des reçus de virement bancaire sur la page de détails de la commande."

#. Author of the plugin
#: ainbae-receipt-upload-for-woocommerce.php
msgid "Ainbae"
msgstr "Ainbae"

#. Author URI of the plugin
#: ainbae-receipt-upload-for-woocommerce.php
msgid "https://www.ainbae.com"
msgstr "https://www.ainbae.com"

#: ainbae-receipt-upload-for-woocommerce.php:29
msgid "Ainbae Receipt Upload requires WooCommerce to be installed and active."
msgstr "Ainbae Téléchargement de reçus nécessite que WooCommerce soit installé et activé."

#: ainbae-receipt-upload-for-woocommerce.php:79
msgid "Verify Your Payment"
msgstr "Vérifiez votre paiement"

#: ainbae-receipt-upload-for-woocommerce.php:80
msgid "Please upload a screenshot of your transaction receipt, or send it directly via WhatsApp to process your order."
msgstr "Veuillez télécharger une capture d'écran de votre reçu de transaction ou l'envoyer directement via WhatsApp pour traiter votre commande."

#: ainbae-receipt-upload-for-woocommerce.php:81
msgid "Click to upload, or drag and drop your receipt file"
msgstr "Cliquez pour télécharger ou glissez-déposez votre fichier de reçu"

