#: ainbae-receipt-upload-for-woocommerce.php:631
#, php-format
msgid "Upload error (code %d)."
msgstr "Erreur de téléchargement (code %d)."

#: ainbae-receipt-upload-for-woocommerce.php:636
msgid "File is too large. Maximum size is 5 MB."
msgstr "Le fichier est trop volumineux. La taille maximale est de 5 Mo."

#: ainbae-receipt-upload-for-woocommerce.php:680
