#: ainbae-receipt-upload-for-woocommerce.php:490
#, php-format
msgid ""
"Hello, I am sharing the payment receipt for my recent order.\n"
"\n"
" *Order Number:* %1$s\n"
" *Amount:* %2$s %3$s\n"
"\n"
" Please find the receipt attached below."
msgstr ""
"Ciao, condivido la ricevuta di pagamento per il mio ordine recente.\n"
"\n"
" *Numero ordine:* %1$s\n"
" *Importo:* %2$s %3$s\n"
"\n"
" Troverai la ricevuta allegata di seguito."

#: ainbae-receipt-upload-for-woocommerce.php:549
msgid "OR"
msgstr "O"

#: ainbae-receipt-upload-for-woocommerce.php:585
msgid "Security check failed. Please refresh the page and try again."
msgstr "Controllo di sicurezza fallito. Aggiorna la pagina e riprova."

#: ainbae-receipt-upload-for-woocommerce.php:591
msgid "Invalid order."
msgstr "Ordine non valido."

#: ainbae-receipt-upload-for-woocommerce.php:599
msgid "You do not have permission to upload a receipt for this order."
msgstr "Non hai il permesso di caricare una ricevuta per questo ordine."

#: ainbae-receipt-upload-for-woocommerce.php:604
msgid "A receipt cannot be uploaded for this order in its current status."
msgstr "Non è possibile caricare una ricevuta per questo ordine nel suo stato attuale."

#: ainbae-receipt-upload-for-woocommerce.php:609
msgid "A receipt has already been uploaded for this order."
msgstr "Una ricevuta è già stata caricata per questo ordine."

#: ainbae-receipt-upload-for-woocommerce.php:622
msgid "Too many upload attempts. Please wait before trying again."
msgstr "Troppi tentativi di caricamento. Attendi prima di riprovare."

#. translators: %d: File upload error code number.
#: ainbae-receipt-upload-for-woocommerce.php:631
#, php-format
msgid "Upload error (code %d)."
msgstr "Errore di caricamento (codice %d)."

#: ainbae-receipt-upload-for-woocommerce.php:636
msgid "File is too large. Maximum size is 5 MB."
msgstr "Il file è troppo grande. La dimensione massima è 5 MB."

#: ainbae-receipt-upload-for-woocommerce.php:680
msgid "Invalid file type. Only JPG, PNG, and PDF are accepted."
msgstr "Tipo di file non valido. Sono accettati solo JPG, PNG e PDF."

#. translators: %s: Date and time when the receipt was uploaded (e.g. 2025-01-17 14:30:00).
#: ainbae-receipt-upload-for-woocommerce.php:692
#, php-format
