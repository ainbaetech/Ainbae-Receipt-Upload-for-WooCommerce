#: ainbae-receipt-upload-for-woocommerce.php:490
#, php-format
msgid ""
"Hello, I am sharing the payment receipt for my recent order.\n"
"\n"
" *Order Number:* %1$s\n"
" *Amount:* %2$s %3$s\n"
"\n"
" Please find the receipt attached below."
msgstr ""
"Olá, estou compartilhando o comprovante de pagamento do meu pedido recente.\n"
"\n"
" *Número do pedido:* %1$s\n"
" *Valor:* %2$s %3$s\n"
"\n"
" Por favor, encontre o comprovante anexado abaixo."

#: ainbae-receipt-upload-for-woocommerce.php:549
msgid "OR"
msgstr "OU"

#: ainbae-receipt-upload-for-woocommerce.php:585
msgid "Security check failed. Please refresh the page and try again."
msgstr "A verificação de segurança falhou. Atualize a página e tente novamente."

