#: ainbae-receipt-upload-for-woocommerce.php:490
#, php-format
msgid ""
"Hello, I am sharing the payment receipt for my recent order.\n"
"\n"
" *Order Number:* %1$s\n"
" *Amount:* %2$s %3$s\n"
"\n"
" Please find the receipt attached below."
msgstr ""
"مرحبًا، أشارك إيصال الدفع لطلبي الأخير.\n"
"\n"
" *رقم الطلب:* %1$s\n"
" *المبلغ:* %2$s %3$s\n"
"\n"
" يرجى الاطلاع على الإيصال المرفق أدناه."

#: ainbae-receipt-upload-for-woocommerce.php:549
msgid "OR"
msgstr "أو"

#: ainbae-receipt-upload-for-woocommerce.php:585
msgid "Security check failed. Please refresh the page and try again."
msgstr "فشل التحقق الأمني. يرجى تحديث الصفحة والمحاولة مرة أخرى."

#: ainbae-receipt-upload-for-woocommerce.php:591
msgid "Invalid order."
msgstr "طلب غير صالح."

#: ainbae-receipt-upload-for-woocommerce.php:599
msgid "You do not have permission to upload a receipt for this order."
msgstr "ليس لديك إذن برفع إيصال لهذا الطلب."

#: ainbae-receipt-upload-for-woocommerce.php:604
msgid "A receipt cannot be uploaded for this order in its current status."
msgstr "لا يمكن رفع إيصال لهذا الطلب في حالته الحالية."

#: ainbae-receipt-upload-for-woocommerce.php:609
msgid "A receipt has already been uploaded for this order."
msgstr "تم رفع إيصال لهذا الطلب مسبقًا."

#: ainbae-receipt-upload-for-woocommerce.php:622
msgid "Too many upload attempts. Please wait before trying again."
msgstr "محاولات رفع كثيرة جدًا. يرجى الانتظار قبل المحاولة مجددًا."

#. translators: %d: File upload error code number.
#: ainbae-receipt-upload-for-woocommerce.php:631
